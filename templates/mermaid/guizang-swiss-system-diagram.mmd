%% For source: use flowchart+subgraph compat (single IKB, hairline groups).
architecture-beta
    group core(cloud)[Core Layer]
    service kernel[Kernel] in core
    service engine[Engine] in core

    group middle(database)[Middle Layer]
    service api[API] in middle
    service data[Data] in middle

    group outer(cloud)[Outer Layer]
    service ui[UI] in outer
    service ext[External] in outer

    kernel --> api
    engine --> data
    api --> ui
    data --> ext

    classDef coreLayer fill:#f0f0ee,stroke:#002FA7,color:#0a0a0a
    classDef middleLayer fill:#f0f0ee,stroke:#FFD500,color:#0a0a0a
    classDef outerLayer fill:#f0f0ee,stroke:#C5E803,color:#0a0a0a

    class core coreLayer
    class middle middleLayer
    class outer outerLayer

